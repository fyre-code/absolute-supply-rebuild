---
import { media } from '../lib/media';
import '../styles/globals.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  path: string;
  keywords: string[];
  imageUrl?: string;
  imageAlt?: string;
}

const { title, description, path, keywords, imageUrl, imageAlt } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={media.logo} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap" rel="stylesheet" />
    <SEO {title} {description} {path} {keywords} imageUrl={imageUrl} imageAlt={imageAlt} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <section class="bg-cream py-20">
      <div class="mx-auto max-w-3xl px-6 text-center" data-reveal>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal">Our Mission</h2>
        <p class="mt-6 text-muted text-lg normal-case leading-relaxed">Whether you're a skilled DIY enthusiast, a professional contractor, or someone envisioning the kitchen or bath of your dreams, Absolute Kitchen and Bath is here to be your ultimate source for cabinets, countertops, and vinyl plank flooring. Trust us to provide you with the highest quality materials and unparalleled service to bring your vision to life.</p>
        <div class="mt-8 flex flex-col items-center gap-4">
          <a href="https://hyppohq.io/f/absolute-supply/contact-absolute-kitchen-and-bath?theme=light" class="inline-block w-64 text-center bg-brand-red hover:bg-brand-red-dark text-white px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Contact Us</a>
          <a href="tel:3213455641" class="inline-block w-64 text-center border border-charcoal hover:bg-charcoal hover:text-white text-charcoal px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Call 321-345-5641</a>
        </div>
      </div>
    </section>
    <Footer />
    <script>
      import '../scripts/reveal.ts';
    </script>
  </body>
</html>
