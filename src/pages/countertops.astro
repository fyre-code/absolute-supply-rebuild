---
import { media } from '../lib/media';
import BaseLayout from '../layouts/BaseLayout.astro';

const keywords = [
  'countertops Melbourne FL',
  'quartz countertops',
  'Pompeii Quartz',
  'kitchen countertops Brevard County',
  'bathroom vanity tops',
  'granite countertops',
  'stone fabrication',
  'countertop installation Melbourne',
  'natural stone countertops',
  'edge profiles',
  'Absolute Kitchen and Bath',
  'countertop showroom',
];
---
<BaseLayout
  title="Countertops & Quartz - Absolute Kitchen and Bath - Melbourne, FL"
  description="Absolute Kitchen and Bath provides quartz and stone countertops in Melbourne, FL. Contact us at 321-345-5641."
  path="/countertops"
  keywords={keywords}
  imageUrl={media.kitchenCounterQuartz}
  imageAlt="Quartz countertop installation"
>
  <section class="relative pt-20 pb-20 bg-charcoal text-white">
    <div class="absolute inset-0 opacity-30">
      <img src={media.kitchenCounterQuartz} alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative mx-auto max-w-7xl px-6 text-center">
      <h1 class="mt-2 text-5xl md:text-6xl font-display font-bold">Countertops</h1>
      <p class="mt-4 max-w-2xl mx-auto text-lg text-white/85 normal-case">Quartz and natural stone, precision-templated and expertly installed.</p>
      <div class="mt-8 flex flex-col items-center gap-4">
        <a href="https://hyppohq.io/f/absolute-supply/contact-absolute-kitchen-and-bath?theme=light" class="inline-block w-64 text-center bg-brand-red hover:bg-brand-red-dark text-white px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Contact Us</a>
        <a href="tel:3213455641" class="inline-block w-64 text-center bg-white hover:bg-cream text-charcoal px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Call 321-345-5641</a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="mx-auto max-w-5xl px-6">
      <div class="text-center" data-reveal>
        <h2 class="mt-3 text-3xl md:text-4xl font-display font-bold text-charcoal text-center">Pompeii Quartz</h2>
      </div>
      <div class="mt-12 flex flex-col items-center text-center" data-reveal>
        <div class="h-20 flex items-center justify-center">
          <img src={media.logoPompeiiQuartz} alt="Pompeii Quartz logo" class="max-h-20 w-auto object-contain" loading="lazy" />
        </div>
        <img src={media.brandPompeiiQuartzSwatches} alt="Pompeii Quartz color samples" class="mt-6 w-full max-w-3xl h-auto object-contain" loading="lazy" />
        <a href="https://pompeiiquartz.com/colors/" target="_blank" rel="noopener noreferrer" class="mt-6 inline-block w-64 text-center bg-brand-red hover:bg-brand-red-dark text-white px-5 py-3 text-sm font-semibold uppercase tracking-wider transition-colors">See More Design Options from Pompeii Quartz</a>
      </div>
    </div>
  </section>

</BaseLayout>
