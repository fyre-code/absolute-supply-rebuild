---
import { media } from '../lib/media';
import BaseLayout from '../layouts/BaseLayout.astro';

const keywords = [
  'luxury vinyl plank flooring Melbourne FL',
  'Shaw flooring Melbourne',
  'Audacity vinyl plank',
  'Happy Feet International flooring',
  'vinyl plank flooring Brevard County',
  'Absolute Supply Company',
  'LVP Space Coast',
];
---
<BaseLayout
  title="Luxury Vinyl Plank Flooring - Absolute Supply Company - Melbourne, FL"
  description="Shaw, Audacity, and Happy Feet International vinyl plank flooring at Absolute Supply Company in Melbourne, FL. Call 321-345-5641."
  path="/flooring"
  keywords={keywords}
  imageUrl={media.flooringInstallation}
  imageAlt="Luxury vinyl plank flooring"
>
  <section class="relative pt-20 pb-24 bg-charcoal text-white overflow-hidden">
    <div id="flooring-hero-bg" class="absolute inset-0">
      <img src={media.flooringHero1} alt="" class="carousel-slide is-active absolute inset-0 w-full h-full object-cover" />
      <img src={media.flooringHero2} alt="" class="carousel-slide absolute inset-0 w-full h-full object-cover" />
      <img src={media.flooringHero3} alt="" class="carousel-slide absolute inset-0 w-full h-full object-cover" />
      <div class="absolute inset-0 bg-charcoal/55"></div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-3 z-10">
      <button data-flooring-dot="0" aria-label="Slide 1" class="w-8 h-3 rounded-full transition-all bg-brand-red"></button>
      <button data-flooring-dot="1" aria-label="Slide 2" class="w-3 h-3 rounded-full transition-all bg-white/50 hover:bg-white"></button>
      <button data-flooring-dot="2" aria-label="Slide 3" class="w-3 h-3 rounded-full transition-all bg-white/50 hover:bg-white"></button>
    </div>
    <div class="relative mx-auto max-w-7xl px-6 text-center">
      <h1 class="mt-2 text-5xl md:text-6xl font-display font-bold">Luxury Vinyl Plank Flooring</h1>
      <div class="mt-8 flex flex-col items-center gap-4">
        <a href="https://hyppohq.io/f/absolute-supply/contact-absolute-kitchen-and-bath?theme=light" class="inline-block w-64 text-center bg-brand-red hover:bg-brand-red-dark text-white px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Contact Us</a>
        <a href="tel:3213455641" class="inline-block w-64 text-center bg-white hover:bg-cream text-charcoal px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Call 321-345-5641</a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="mx-auto max-w-6xl px-6 space-y-20">
      <div data-reveal class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <img src={media.photoShaw} alt="Shaw vinyl plank flooring" class="w-full h-auto" loading="lazy" />
        <div class="text-center">
          <div class="h-20 flex items-center justify-center">
            <img src={media.logoShaw} alt="Shaw logo" class="max-h-20 w-auto object-contain" loading="lazy" />
          </div>
          <p class="mt-4 text-muted text-lg normal-case leading-relaxed">Shaw, a leader in the flooring industry, brings their expertise and innovation to every product they create. Their vinyl plank flooring options showcase remarkable craftsmanship, durability, and stunning designs that effortlessly elevate any space. Whether you prefer a classic wood look or a contemporary style, Shaw's vinyl plank flooring offers an array of options to suit your aesthetic preferences and lifestyle.</p>
          <a href="https://shawfloors.com/en-us/vinyl-luxuryplankandtile" target="_blank" rel="noopener noreferrer" class="mt-6 inline-block w-64 text-center bg-brand-red hover:bg-brand-red-dark text-white px-5 py-3 text-sm font-semibold uppercase tracking-wider transition-colors">See More Design Options from Shaw</a>
        </div>
      </div>

      <div data-reveal class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div class="text-center">
          <div class="h-20 flex items-center justify-center">
            <img src={media.logoAudacity} alt="Audacity logo" class="max-h-20 w-auto object-contain" loading="lazy" />
          </div>
          <p class="mt-4 text-muted text-lg normal-case leading-relaxed">Audacity, as the name suggests, pushes the boundaries of what vinyl plank flooring can achieve. Their innovative engineering creates flooring that is not only visually stunning but also exceptionally resilient. Audacity's unique construction ensures superior water resistance, making it ideal for areas prone to moisture, such as kitchens and bathrooms. Experience the ultimate peace of mind with Audacity's remarkable vinyl plank flooring.</p>
          <a href="https://audacityflooring.com/collections-hybrid-products/" target="_blank" rel="noopener noreferrer" class="mt-6 inline-block w-64 text-center bg-brand-red hover:bg-brand-red-dark text-white px-5 py-3 text-sm font-semibold uppercase tracking-wider transition-colors">See More Design Options from Audacity</a>
        </div>
        <img src={media.photoAudacity} alt="Audacity vinyl plank flooring" class="w-full h-auto" loading="lazy" />
      </div>

      <div data-reveal class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <img src={media.photoHappyFeet} alt="Happy Feet International vinyl plank flooring" class="w-full h-auto" loading="lazy" />
        <div class="text-center">
          <div class="h-20 flex items-center justify-center">
            <img src={media.logoHappyFeet} alt="Happy Feet International logo" class="max-h-20 w-auto object-contain" loading="lazy" />
          </div>
          <p class="mt-4 text-muted text-lg normal-case leading-relaxed">Happy Feet International is dedicated to delivering vinyl plank flooring that combines beauty and functionality. Their meticulous attention to detail results in luxurious, realistic wood and stone textures, while their commitment to performance ensures that their flooring stands up to the demands of daily life. With Happy Feet International, you can enjoy the beauty of natural materials without compromising on durability and easy maintenance.</p>
          <a href="https://www.happyfeetinternational.com/products/" target="_blank" rel="noopener noreferrer" class="mt-6 inline-block w-64 text-center bg-brand-red hover:bg-brand-red-dark text-white px-5 py-3 text-sm font-semibold uppercase tracking-wider transition-colors">See More Design Options from Happy Feet</a>
        </div>
      </div>

      <div class="mt-8 flex flex-col items-center gap-4" data-reveal>
        <a href="https://hyppohq.io/f/absolute-supply/contact-absolute-kitchen-and-bath?theme=light" class="inline-block w-64 text-center bg-brand-red hover:bg-brand-red-dark text-white px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Contact Us</a>
        <a href="tel:3213455641" class="inline-block w-64 text-center border border-charcoal hover:bg-charcoal hover:text-white text-charcoal px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Call 321-345-5641</a>
      </div>
    </div>
  </section>


<script>
  const bg = document.getElementById('flooring-hero-bg');
  if (bg) {
    const slides = bg.querySelectorAll<HTMLImageElement>('.carousel-slide');
    const dots = document.querySelectorAll<HTMLButtonElement>('[data-flooring-dot]');
    let current = 0;
    let timer: number | undefined;

    const go = (i: number) => {
      slides[current].classList.remove('is-active');
      dots[current]?.classList.replace('bg-brand-red', 'bg-white/50');
      dots[current]?.classList.remove('w-8');
      dots[current]?.classList.add('w-3');
      current = (i + slides.length) % slides.length;
      slides[current].classList.add('is-active');
      dots[current]?.classList.replace('bg-white/50', 'bg-brand-red');
      dots[current]?.classList.remove('w-3');
      dots[current]?.classList.add('w-8');
    };

    const start = () => { timer = window.setInterval(() => go(current + 1), 5000); };
    const stop = () => { if (timer) window.clearInterval(timer); };

    dots.forEach((d, i) => d.addEventListener('click', () => { stop(); go(i); start(); }));
    start();
  }
</script>
</BaseLayout>
