---
import { media } from '../lib/media';
import BaseLayout from '../layouts/BaseLayout.astro';

const keywords = [
  'luxury vinyl plank flooring Melbourne FL',
  'Shaw flooring Melbourne',
  'Audacity vinyl plank',
  'Happy Feet International flooring',
  'vinyl plank flooring Brevard County',
  'Absolute Supply Company',
  'LVP Space Coast',
];
---
<BaseLayout
  title="Luxury Vinyl Plank Flooring - Absolute Supply Company - Melbourne, FL"
  description="Shaw, Audacity, and Happy Feet International vinyl plank flooring at Absolute Supply Company in Melbourne, FL. Call 321-345-5641."
  path="/flooring"
  keywords={keywords}
  imageUrl={media.flooringInstallation}
  imageAlt="Luxury vinyl plank flooring"
>
  <section class="relative pt-20 pb-20 bg-charcoal text-white">
    <div class="absolute inset-0 opacity-30">
      <img src={media.flooringInstallation} alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative mx-auto max-w-7xl px-6 text-center">
      <h1 class="mt-2 text-5xl md:text-6xl font-display font-bold">Luxury Vinyl Plank Flooring</h1>
      <p class="mt-6 max-w-3xl mx-auto text-lg text-white/90 normal-case leading-relaxed">At Absolute Supply, we take pride in offering an extensive range of vinyl plank flooring products from renowned brands such as Shaw, Happy Feet International, and Audacity. With our exceptional selection, unbeatable quality, and unwavering commitment to customer satisfaction, we are your go-to destination for all your vinyl plank flooring needs.</p>
      <div class="mt-8 flex flex-col items-center gap-4">
        <a href="https://hyppohq.io/f/absolute-supply/contact-absolute-kitchen-and-bath?theme=light" class="inline-block w-64 text-center bg-brand-red hover:bg-brand-red-dark text-white px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Contact Us</a>
        <a href="tel:3213455641" class="inline-block w-64 text-center bg-white hover:bg-cream text-charcoal px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Call 321-345-5641</a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="mx-auto max-w-4xl px-6 space-y-16">
      <div data-reveal class="text-center">
        <div class="h-24 flex items-center justify-center">
          <img src={media.logoShaw} alt="Shaw logo" class="max-h-24 w-auto object-contain" loading="lazy" />
        </div>
        <p class="mt-6 text-muted text-lg normal-case leading-relaxed">Shaw, a leader in the flooring industry, brings their expertise and innovation to every product they create. Their vinyl plank flooring options showcase remarkable craftsmanship, durability, and stunning designs that effortlessly elevate any space. Whether you prefer a classic wood look or a contemporary style, Shaw's vinyl plank flooring offers an array of options to suit your aesthetic preferences and lifestyle.</p>
      </div>

      <div data-reveal class="text-center">
        <div class="h-24 flex items-center justify-center">
          <img src={media.logoAudacity} alt="Audacity logo" class="max-h-24 w-auto object-contain" loading="lazy" />
        </div>
        <p class="mt-6 text-muted text-lg normal-case leading-relaxed">Audacity, as the name suggests, pushes the boundaries of what vinyl plank flooring can achieve. Their innovative engineering creates flooring that is not only visually stunning but also exceptionally resilient. Audacity's unique construction ensures superior water resistance, making it ideal for areas prone to moisture, such as kitchens and bathrooms. Experience the ultimate peace of mind with Audacity's remarkable vinyl plank flooring.</p>
      </div>

      <div data-reveal class="text-center">
        <div class="h-24 flex items-center justify-center">
          <img src={media.logoHappyFeet} alt="Happy Feet International logo" class="max-h-24 w-auto object-contain" loading="lazy" />
        </div>
        <p class="mt-6 text-muted text-lg normal-case leading-relaxed">Happy Feet International is dedicated to delivering vinyl plank flooring that combines beauty and functionality. Their meticulous attention to detail results in luxurious, realistic wood and stone textures, while their commitment to performance ensures that their flooring stands up to the demands of daily life. With Happy Feet International, you can enjoy the beauty of natural materials without compromising on durability and easy maintenance.</p>
      </div>
    </div>
  </section>

</BaseLayout>
