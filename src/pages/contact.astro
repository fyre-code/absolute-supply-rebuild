---
import BaseLayout from '../layouts/BaseLayout.astro';
import HyppoForm from '../components/HyppoForm.astro';

const keywords = [
  'contact Absolute Kitchen and Bath',
  'kitchen showroom Melbourne FL',
  'cabinet quote Melbourne',
  'countertop quote Brevard County',
  'flooring quote Melbourne',
  'kitchen consultation',
  'bath remodel consultation',
  'showroom hours Melbourne FL',
  '321-345-5641',
  '1385 W New Haven Avenue',
  'Absolute Kitchen and Bath contact',
  'free 3D design',
];
---
<BaseLayout
  title="Contact Us - Absolute Kitchen and Bath - Melbourne, FL"
  description="Contact Absolute Kitchen and Bath in Melbourne, FL for cabinets, flooring, and countertops. Phone: 321-345-5641."
  path="/contact"
  keywords={keywords}
>
  <section class="pt-32 pb-12 bg-charcoal text-white">
    <div class="mx-auto max-w-7xl px-6">
      <span class="text-brand-red font-semibold text-sm uppercase tracking-widest">Contact</span>
      <h1 class="mt-2 text-5xl md:text-6xl font-display font-bold">Let's Talk</h1>
      <p class="mt-4 max-w-2xl text-lg text-white/85 normal-case">Stop in, call, or send a message. We'll get back to you within one business day.</p>
    </div>
  </section>

  <section class="py-20 bg-cream">
    <div class="mx-auto max-w-6xl px-6 grid grid-cols-1 lg:grid-cols-2 gap-10">
      <div data-reveal>
        <h2 class="text-3xl font-display font-bold text-charcoal">Showroom</h2>
        <p class="mt-4 text-muted text-lg normal-case">1385 W New Haven Avenue<br/>Melbourne, FL 32904</p>

        <h3 class="mt-8 text-xl font-display font-bold text-charcoal">Phone</h3>
        <p class="mt-2"><a href="tel:3213455641" class="text-brand-red text-xl font-semibold hover:text-brand-red-dark normal-case">321-345-5641</a></p>

        <h3 class="mt-8 text-xl font-display font-bold text-charcoal">Email</h3>
        <p class="mt-2 break-all"><a href="mailto:absolutesupplyllc@outlook.com" class="text-brand-red font-semibold hover:text-brand-red-dark normal-case">absolutesupplyllc@outlook.com</a></p>

        <h3 class="mt-8 text-xl font-display font-bold text-charcoal">Hours</h3>
        <dl class="mt-2 grid grid-cols-[auto_1fr] gap-x-4 gap-y-1 normal-case text-charcoal">
          <dt class="text-muted">Mon – Sat</dt><dd>9:00 AM – 6:00 PM</dd>
          <dt class="text-muted">Sunday</dt><dd>Closed</dd>
        </dl>

        <div class="mt-10 aspect-[4/3] bg-white border border-cream overflow-hidden">
          <iframe
            src="https://www.google.com/maps?q=1385+W+New+Haven+Ave,+Melbourne,+FL+32904&output=embed"
            class="w-full h-full border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Absolute Kitchen and Bath showroom map"
          ></iframe>
        </div>
      </div>

      <div data-reveal>
        <HyppoForm heading="Send Us a Message" />
      </div>
    </div>
  </section>
</BaseLayout>
