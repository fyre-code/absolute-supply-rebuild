---
import { media } from '../lib/media';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import ServiceCard from '../components/ServiceCard.astro';

const slides = [
  {
    image: media.kitchenShowroomHero,
    alt: 'Modern kitchen showroom with custom cabinetry',
    headline: 'Kitchens & Baths Built Around You',
    sub: 'Custom cabinets, premium countertops, and flooring — designed and installed by a Melbourne, FL team that takes craft seriously.',
  },
  {
    image: media.kitchenCabinetryFinished,
    alt: 'Finished custom kitchen cabinetry',
    headline: 'Premium Cabinetry, Local Service',
    sub: 'Fabuwood, Schrock, Mantra, Northpoint — top brands, expert design, complimentary 3D consultations.',
  },
  {
    image: media.kitchenCounterQuartz,
    alt: 'Quartz kitchen countertop',
    headline: 'Countertops That Define the Room',
    sub: 'Pompeii Quartz and natural stone, fabricated and installed with precision.',
  },
  {
    image: media.cabinetShowcase,
    alt: 'Cabinet showcase from Absolute Kitchen and Bath showroom',
    headline: 'Walk the Showroom',
    sub: 'Real samples, real slabs, real installs — see what your kitchen could look like before you commit.',
  },
];

const keywords = [
  'kitchen and bath Melbourne FL',
  'custom cabinets Melbourne',
  'countertop installation Brevard County',
  'flooring installation Melbourne FL',
  'kitchen remodel Melbourne FL',
  'bathroom remodel Melbourne',
  'Fabuwood cabinets',
  'Pompeii Quartz dealer',
  'showroom Melbourne FL',
  'Absolute Kitchen and Bath',
  '3D kitchen design',
  'Brevard County remodeling',
];
---
<BaseLayout
  title="Absolute Kitchen and Bath - Melbourne, FL Remodeling"
  description="Absolute Kitchen and Bath provides cabinets, flooring, and countertops in Melbourne, FL. Contact us at 321-345-5641."
  path="/"
  keywords={keywords}
  imageUrl={media.kitchenShowroomHero}
  imageAlt="Absolute Kitchen and Bath showroom"
>
  <HeroCarousel slides={slides} />

  <section class="py-24 bg-cream">
    <div class="mx-auto max-w-7xl px-6">
      <div class="max-w-3xl mx-auto text-center" data-reveal>
        <span class="text-brand-red font-semibold text-sm uppercase tracking-widest">What We Do</span>
        <h2 class="mt-3 text-4xl md:text-5xl font-display font-bold text-charcoal">Three Specialties. One Showroom.</h2>
        <p class="mt-4 text-lg text-muted normal-case">From the first sketch to the final install, we handle the parts of your home that get used every day — and we do it under one roof.</p>
      </div>

      <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-6 reveal-stagger">
        <ServiceCard
          href="/cabinets"
          image={media.kitchenCabinetryFinished}
          alt="Custom kitchen cabinetry"
          title="Cabinets"
          description="Custom kitchen and bath cabinetry from Fabuwood, Schrock, Mantra, and Northpoint. Complimentary 3D design."
        />
        <ServiceCard
          href="/countertops"
          image={media.kitchenCounterQuartz}
          alt="Quartz countertop"
          title="Countertops"
          description="Pompeii Quartz and natural stone. Precision-fabricated edges, expert templating and installation."
        />
        <ServiceCard
          href="/flooring"
          image={media.flooringInstallation}
          alt="Flooring installation"
          title="Flooring"
          description="Luxury vinyl plank, tile, and hardwood. Durable, beautiful, and installed by professionals."
        />
      </div>
    </div>
  </section>

  <section class="relative py-24">
    <div class="absolute inset-0">
      <img src={media.kitchenShowroomHero} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-charcoal/55"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-6">
      <div data-reveal class="text-center text-white">
        <h2 class="text-4xl md:text-5xl font-display font-bold">Why Us</h2>
        <p class="mt-5 max-w-3xl mx-auto text-white/90 text-lg normal-case leading-relaxed">Absolute Supply is your trusted partner in remodels and renovations, offering high-quality cabinets, countertops, vinyl plank flooring, and cabinet hardware. We deliver exceptional customer service, provide innovative and stylish products, and promote sustainability in the industry. Our goal is to empower you to transform your spaces into dream homes, with quality and value at the forefront of every project.</p>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6 reveal-stagger">
        <div data-reveal class="bg-white/10 backdrop-blur-sm border border-white/20 p-8 text-center text-white">
          <img src={media.iconLocallyOwned} alt="" class="mx-auto w-20 h-20" width="80" height="80" loading="lazy" />
          <h3 class="mt-3 text-xl font-display font-bold">Locally Owned</h3>
          <p class="mt-2 text-white/85 normal-case leading-relaxed">For nearly two decades, our family has proudly called the vibrant Space Coast our home. We have established deep roots in this community and are wholeheartedly dedicated to delivering superior products at prices that won't break the bank.</p>
        </div>

        <div data-reveal class="bg-white/10 backdrop-blur-sm border border-white/20 p-8 text-center text-white">
          <img src={media.iconQualityProducts} alt="" class="mx-auto w-20 h-20" width="80" height="80" loading="lazy" />
          <h3 class="mt-3 text-xl font-display font-bold">Quality Products</h3>
          <p class="mt-2 text-white/85 normal-case leading-relaxed">We take immense pride in our selection of top-notch cabinet, and flooring products. What sets us apart is that we don't just sell these products; we personally use them in our own homes and businesses, ensuring that we offer nothing but the best to our valued customers</p>
        </div>

        <div data-reveal class="bg-white/10 backdrop-blur-sm border border-white/20 p-8 text-center text-white">
          <img src={media.iconCustomerService} alt="" class="mx-auto w-20 h-20" width="80" height="80" loading="lazy" />
          <h3 class="mt-3 text-xl font-display font-bold">Customer Service</h3>
          <p class="mt-2 text-white/85 normal-case leading-relaxed">We are here for you, our friends and neighbors in the beautiful Space Coast. Whether you have a question, need assistance, or want to explore our wide range of products, we're just a phone call or an email away. Don't hesitate to reach out to us—we are eager and ready to provide you with exceptional service and support!</p>
        </div>

        <div data-reveal class="bg-white/10 backdrop-blur-sm border border-white/20 p-8 text-center text-white">
          <img src={media.iconDesignServices} alt="" class="mx-auto w-20 h-20" width="80" height="80" loading="lazy" />
          <h3 class="mt-3 text-xl font-display font-bold">Design Services</h3>
          <p class="mt-2 text-white/85 normal-case leading-relaxed">Transforming your kitchen or bath project from imagination to reality is made easier with our 3D design service. Visualize your vision in stunning detail before making any commitments. What's more, our estimates are always provided at no cost to you. Take the first step towards your dream space.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-charcoal text-white">
    <div class="mx-auto max-w-4xl px-6 text-center" data-reveal>
      <h2 class="text-4xl md:text-5xl font-display font-bold">Ready to Start Your Project?</h2>
      <p class="mt-4 text-lg text-white/80 normal-case">Stop by the showroom or request a free quote. We'll help you map out the kitchen, bath, or floor you've been picturing.</p>
      <div class="mt-8 flex flex-col items-center gap-4">
        <a href="https://hyppohq.io/f/absolute-supply/contact-absolute-kitchen-and-bath?theme=light" class="inline-block w-64 text-center bg-brand-red hover:bg-brand-red-dark text-white px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Contact Us</a>
        <a href="tel:3213455641" class="inline-block w-64 text-center border border-white/70 hover:bg-white hover:text-charcoal text-white px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Call 321-345-5641</a>
      </div>
    </div>
  </section>
</BaseLayout>
