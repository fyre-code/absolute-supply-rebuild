---
import { media } from '../lib/media';
import BaseLayout from '../layouts/BaseLayout.astro';

const keywords = [
  'kitchen cabinets Melbourne FL',
  'custom cabinets',
  'bath cabinets Melbourne',
  'Fabuwood cabinets',
  'Schrock cabinets',
  'Mantra cabinets',
  'Northpoint cabinets',
  'cabinet refacing',
  'Brevard County cabinets',
  'kitchen remodel',
  'cabinet showroom',
  'Absolute Kitchen and Bath',
];

const brands = [
  { name: 'Northpoint', logo: media.logoNorthpoint, swatches: media.brandNorthpointSwatches, href: 'https://www.hardwareresources.com/northpoint-cabinets' },
  { name: 'Fabuwood', logo: media.logoFabuwood, swatches: media.brandFabuwoodSwatches, href: 'https://www.fabuwood.com/doors/' },
  { name: 'Schrock', logo: media.logoSchrock, swatches: media.brandSchrockSwatches, href: 'https://www.schrock.com/products' },
  { name: 'Mantra', logo: media.logoMantra, swatches: media.brandMantraSwatches, href: 'https://www.mantracabinets.com/wp-content/uploads/9301.MAN_FullLine.pdf' },
];

---
<BaseLayout
  title="Custom Cabinets - Absolute Kitchen and Bath - Melbourne, FL"
  description="Absolute Kitchen and Bath provides custom kitchen and bath cabinets in Melbourne, FL. Contact us at 321-345-5641."
  path="/cabinets"
  keywords={keywords}
  imageUrl={media.kitchenCabinetryFinished}
  imageAlt="Custom kitchen cabinetry"
>
  <section class="relative pt-20 pb-20 bg-charcoal text-white">
    <div class="absolute inset-0 opacity-30">
      <img src={media.kitchenCabinetryFinished} alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative mx-auto max-w-7xl px-6 text-center">
      <h1 class="mt-2 text-5xl md:text-6xl font-display font-bold">Kitchen, Bathroom Cabinets, Countertops, and Hardware</h1>
      <p class="mt-6 max-w-3xl mx-auto text-lg text-white/90 normal-case leading-relaxed">Experience the perfect blend of quality, style, and customization options with our exceptional cabinet offerings. Let Absolute Supply be your partner in creating spaces that reflect your distinct vision and transform your home.</p>
      <div class="mt-8 flex flex-col items-center gap-4">
        <a href="https://hyppohq.io/f/absolute-supply/contact-absolute-kitchen-and-bath?theme=light" class="inline-block w-64 text-center bg-brand-red hover:bg-brand-red-dark text-white px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Contact Us</a>
        <a href="tel:3213455641" class="inline-block w-64 text-center bg-white hover:bg-cream text-charcoal px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Call 321-345-5641</a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center" data-reveal>
        <h2 class="mt-3 text-3xl md:text-4xl font-display font-bold text-charcoal">Premium Lines We Carry</h2>
      </div>
      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-10 reveal-stagger">
        {brands.map((b) => (
          <div data-reveal class="flex flex-col items-center text-center h-full">
            <div class="h-32 flex items-center justify-center">
              <img src={b.logo} alt={`${b.name} logo`} class="max-h-32 w-auto object-contain" loading="lazy" />
            </div>
            <div class="mt-5 h-56 w-full flex items-center justify-center">
              <img src={b.swatches} alt={`${b.name} cabinet finish swatches`} class="max-h-56 w-full object-contain" loading="lazy" />
            </div>
            <a href={b.href} target="_blank" rel="noopener noreferrer" class="mt-auto pt-6 inline-block">
              <span class="inline-block w-64 text-center bg-brand-red hover:bg-brand-red-dark text-white px-5 py-3 text-sm font-semibold uppercase tracking-wider transition-colors">See More Design Options from {b.name}</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>


</BaseLayout>
