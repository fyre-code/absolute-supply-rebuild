---
import { media } from '../lib/media';
import BaseLayout from '../layouts/BaseLayout.astro';

const keywords = [
  'kitchen cabinets Melbourne FL',
  'custom cabinets',
  'bath cabinets Melbourne',
  'Fabuwood cabinets',
  'Schrock cabinets',
  'Mantra cabinets',
  'Northpoint cabinets',
  'cabinet refacing',
  'Brevard County cabinets',
  'kitchen remodel',
  'cabinet showroom',
  'Absolute Kitchen and Bath',
];

const brands = [
  { name: 'Northpoint', logo: media.logoNorthpoint, swatches: media.brandNorthpointSwatches, href: 'https://www.hardwareresources.com/northpoint-cabinets' },
  { name: 'Fabuwood', logo: media.logoFabuwood, swatches: media.brandFabuwoodSwatches, href: 'https://www.fabuwood.com/doors/' },
  { name: 'Schrock', logo: media.logoSchrock, swatches: media.brandSchrockSwatches, href: 'https://www.schrock.com/products' },
  { name: 'Mantra', logo: media.logoMantra, swatches: media.brandMantraSwatches, href: 'https://www.mantracabinets.com/wp-content/uploads/9301.MAN_FullLine.pdf' },
];

---
<BaseLayout
  title="Custom Cabinets - Absolute Kitchen and Bath - Melbourne, FL"
  description="Absolute Kitchen and Bath provides custom kitchen and bath cabinets in Melbourne, FL. Contact us at 321-345-5641."
  path="/cabinets"
  keywords={keywords}
  imageUrl={media.kitchenCabinetryFinished}
  imageAlt="Custom kitchen cabinetry"
>
  <section class="relative pt-20 pb-24 bg-charcoal text-white overflow-hidden">
    <div id="cabinets-hero-bg" class="absolute inset-0">
      <img src={media.kitchenCabinetryFinished} alt="" class="carousel-slide is-active absolute inset-0 w-full h-full object-cover" />
      <img src={media.cabinetsHero2} alt="" class="carousel-slide absolute inset-0 w-full h-full object-cover" />
      <img src={media.cabinetsHero3} alt="" class="carousel-slide absolute inset-0 w-full h-full object-cover" />
      <div class="absolute inset-0 bg-charcoal/55"></div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-3 z-10">
      <button data-cabinets-dot="0" aria-label="Slide 1" class="w-8 h-3 rounded-full transition-all bg-brand-red"></button>
      <button data-cabinets-dot="1" aria-label="Slide 2" class="w-3 h-3 rounded-full transition-all bg-white/50 hover:bg-white"></button>
      <button data-cabinets-dot="2" aria-label="Slide 3" class="w-3 h-3 rounded-full transition-all bg-white/50 hover:bg-white"></button>
    </div>
    <div class="relative mx-auto max-w-7xl px-6 text-center">
      <h1 class="mt-2 text-5xl md:text-6xl font-display font-bold">Kitchen and Bathroom Cabinets and Hardware</h1>
      <div class="mt-8 flex flex-col items-center gap-4">
        <a href="https://hyppohq.io/f/absolute-supply/contact-absolute-kitchen-and-bath?theme=light" class="inline-block w-64 text-center bg-brand-red hover:bg-brand-red-dark text-white px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Contact Us</a>
        <a href="tel:3213455641" class="inline-block w-64 text-center bg-white hover:bg-cream text-charcoal px-7 py-3.5 text-sm font-semibold uppercase tracking-wider transition-colors">Call 321-345-5641</a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center" data-reveal>
        <h2 class="mt-3 text-3xl md:text-4xl font-display font-bold text-charcoal">Premium Lines We Carry</h2>
      </div>
      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-10 reveal-stagger">
        {brands.map((b, i) => (
          <div data-reveal class:list={['flex flex-col items-center text-center h-full pb-8 md:pb-0', i < brands.length - 1 && 'border-b border-charcoal/15 md:border-0']}>
            <div class="h-24 md:h-32 flex items-center justify-center">
              <img src={b.logo} alt={`${b.name} logo`} class="max-h-24 md:max-h-32 w-auto object-contain" loading="lazy" />
            </div>
            <div class="mt-2 md:mt-5 h-48 md:h-56 w-full flex items-center justify-center">
              <img src={b.swatches} alt={`${b.name} cabinet finish swatches`} class="max-h-48 md:max-h-56 w-full object-contain" loading="lazy" />
            </div>
            <a href={b.href} target="_blank" rel="noopener noreferrer" class="mt-2 md:mt-auto md:pt-6 inline-block">
              <span class="inline-block w-64 text-center bg-brand-red hover:bg-brand-red-dark text-white px-5 py-3 text-sm font-semibold uppercase tracking-wider transition-colors">See More Design Options from {b.name}</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>



<script>
  const bg = document.getElementById('cabinets-hero-bg');
  if (bg) {
    const slides = bg.querySelectorAll<HTMLImageElement>('.carousel-slide');
    const dots = document.querySelectorAll<HTMLButtonElement>('[data-cabinets-dot]');
    let current = 0;
    let timer: number | undefined;

    const go = (i: number) => {
      slides[current].classList.remove('is-active');
      dots[current]?.classList.replace('bg-brand-red', 'bg-white/50');
      dots[current]?.classList.remove('w-8');
      dots[current]?.classList.add('w-3');
      current = (i + slides.length) % slides.length;
      slides[current].classList.add('is-active');
      dots[current]?.classList.replace('bg-white/50', 'bg-brand-red');
      dots[current]?.classList.remove('w-3');
      dots[current]?.classList.add('w-8');
    };

    const start = () => { timer = window.setInterval(() => go(current + 1), 5000); };
    const stop = () => { if (timer) window.clearInterval(timer); };

    dots.forEach((d, i) => d.addEventListener('click', () => { stop(); go(i); start(); }));
    start();
  }
</script>
</BaseLayout>
