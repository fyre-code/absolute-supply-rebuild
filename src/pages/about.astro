---
import BaseLayout from '../layouts/BaseLayout.astro';

const keywords = [
  'about Absolute Kitchen and Bath',
  'Melbourne FL remodeling company',
  'kitchen showroom Melbourne',
  'bath showroom Brevard County',
  'local remodeling contractor',
  'family-owned remodeling',
  'Melbourne Florida cabinets',
  'kitchen designer Melbourne FL',
  'Absolute Kitchen and Bath team',
  'showroom 1385 W New Haven',
  'kitchen renovation experts',
  'bathroom renovation Melbourne',
];
---
<BaseLayout
  title="About Us - Absolute Kitchen and Bath - Melbourne, FL"
  description="Learn about Absolute Kitchen and Bath, serving Melbourne, FL with cabinets, flooring, and countertops. Contact us at 321-345-5641."
  path="/about"
  keywords={keywords}
>
  <section class="relative pt-32 pb-20 bg-charcoal text-white">
    <div class="absolute inset-0 opacity-30">
      <img src="/images/kitchen-showroom-hero.jpg" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative mx-auto max-w-7xl px-6">
      <span class="text-brand-red font-semibold text-sm uppercase tracking-widest">About</span>
      <h1 class="mt-2 text-5xl md:text-6xl font-display font-bold">Local. Hands-On. Built to Last.</h1>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="mx-auto max-w-4xl px-6">
      <div data-reveal>
        <p class="text-xl text-charcoal normal-case leading-relaxed">Absolute Kitchen and Bath is a Melbourne, FL showroom specializing in cabinets, countertops, and flooring. We work with homeowners and contractors throughout Brevard County to deliver finished spaces that look great and hold up to real life.</p>

        <h2 class="mt-12 text-3xl font-display font-bold text-charcoal">What We Believe</h2>
        <p class="mt-4 text-muted text-lg normal-case leading-relaxed">A kitchen or bath project should be straightforward. You should know what you're getting, who's installing it, and what it costs — before the first cabinet goes in. We design in 3D so you can see the finished room before we order anything, and we use a single point of contact from quote through final walkthrough.</p>

        <h2 class="mt-12 text-3xl font-display font-bold text-charcoal">Visit the Showroom</h2>
        <p class="mt-4 text-muted text-lg normal-case leading-relaxed">Walk in and see real cabinet samples, full slabs of quartz and stone, and flooring you can put your hand on. Our designers are happy to talk through your project whether you're ready to buy this week or just exploring ideas.</p>

        <div class="mt-8 p-6 bg-cream border-l-4 border-brand-red">
          <p class="font-semibold text-charcoal normal-case">1385 W New Haven Avenue<br/>Melbourne, FL 32904</p>
          <p class="mt-2 normal-case"><a href="tel:3213455641" class="text-brand-red font-semibold hover:text-brand-red-dark">321-345-5641</a></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
