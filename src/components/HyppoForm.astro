---
interface Props {
  embedUrl?: string;
  heading?: string;
}
const { embedUrl, heading = 'Get in Touch' } = Astro.props;
---
<div class="bg-white border border-cream p-6 md:p-10">
  <h2 class="text-3xl font-display font-semibold text-charcoal mb-2">{heading}</h2>
  <p class="text-muted text-sm normal-case mb-6">Tell us about your project. We'll be in touch within one business day.</p>

  {embedUrl ? (
    <iframe src={embedUrl} class="w-full min-h-[640px] border-0" title="Contact form" loading="lazy"></iframe>
  ) : (
    <div data-hyppo-form-pending class="border-2 border-dashed border-cream rounded p-8 text-center">
      <p class="text-muted text-sm normal-case">
        Form embed pending. The developer will provide the HyppoCRM-hosted form URL — drop it into <code class="bg-cream px-1.5 py-0.5 rounded text-charcoal">HyppoForm</code>'s <code class="bg-cream px-1.5 py-0.5 rounded text-charcoal">embedUrl</code> prop.
      </p>
      <p class="mt-4 text-sm normal-case">
        In the meantime, please call <a href="tel:3213455641" class="text-brand-red font-semibold">321-345-5641</a> or email <a href="mailto:absolutesupplyllc@outlook.com" class="text-brand-red font-semibold">absolutesupplyllc@outlook.com</a>.
      </p>
    </div>
  )}
</div>
