---
interface Props {
  heading?: string;
}
const { heading = 'Get in Touch' } = Astro.props;
const EMBED_SRC = 'https://hyppohq.io/api/v1/forms/embed/absolute-supply/contact-absolute-kitchen-and-bath';
const PUBLIC_URL = 'https://hyppohq.io/f/absolute-supply/contact-absolute-kitchen-and-bath?theme=light';
---
<div class="bg-white border border-cream p-6 md:p-10">
  <h2 class="text-3xl font-display font-semibold text-charcoal mb-2">{heading}</h2>
  <p class="text-muted text-sm normal-case mb-6">Tell us about your project. We'll be in touch within one business day.</p>

  <div data-hyppo-form-host class="min-h-[480px]">
    <noscript>
      <p class="text-sm normal-case">
        To use our contact form, please enable JavaScript or
        <a href={PUBLIC_URL} class="text-brand-red font-semibold underline">open the form in a new tab</a>.
      </p>
    </noscript>
  </div>

  <p class="mt-6 text-xs text-muted normal-case">
    Prefer to reach us directly? Call <a href="tel:3213455641" class="text-brand-red font-semibold">321-345-5641</a> or email <a href="mailto:absolutesupplyllc@outlook.com" class="text-brand-red font-semibold">absolutesupplyllc@outlook.com</a>.
  </p>
</div>

<script is:inline src={EMBED_SRC} async></script>
