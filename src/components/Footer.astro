---
<footer class="bg-black text-white">
  <div class="mx-auto max-w-7xl px-6 py-14 text-center">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 items-start justify-items-center">
      <div>
        <a href="/" class="inline-block">
          <img src={media.logoOnBlack} alt="Absolute Kitchen and Bath" class="h-64 w-auto" width="320" height="316" />
        </a>
      </div>

      <div class="space-y-2 text-sm">
        <h3 class="text-base font-display uppercase tracking-wider text-brand-red mb-3">Contact</h3>
        <p>1385 W New Haven Avenue<br />Melbourne, FL 32904</p>
        <p><a href="tel:3213455641" class="hover:text-brand-red transition-colors">321-345-5641</a></p>
        <p><a href="mailto:absolutesupplyllc@outlook.com" class="hover:text-brand-red transition-colors break-all">absolutesupplyllc@outlook.com</a></p>

        <h4 class="text-base font-display uppercase tracking-wider text-brand-red mt-5 mb-2">Hours</h4>
        <dl class="inline-grid grid-cols-[auto_1fr] gap-x-3 gap-y-1 text-white/80 text-left">
          <dt>Mon – Sat</dt><dd>9:00 AM – 6:00 PM</dd>
          <dt>Sunday</dt><dd>Closed</dd>
        </dl>
      </div>

      <div>
        <h3 class="text-base font-display uppercase tracking-wider text-brand-red mb-3">Follow Us</h3>
        <ul class="inline-flex flex-col gap-2 items-start text-left">
          {socials.map((s) => (
            <li>
              <a href={s.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 text-sm hover:text-brand-red transition-colors group">
                <span class="w-9 h-9 rounded-full bg-white/10 group-hover:bg-brand-red flex items-center justify-center transition-colors">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d={s.icon} /></svg>
                </span>
                <span>{s.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/10 flex flex-wrap gap-4 text-sm justify-center">
      <a href="/privacy-policy" class="hover:text-brand-red transition-colors">Privacy Policy</a>
      <span class="text-white/30">|</span>
      <a href="/terms-of-service" class="hover:text-brand-red transition-colors">Terms of Service</a>
    </div>

    <div class="mt-4 text-sm text-white/70">
      © {year} Absolute Kitchen and Bath. All rights reserved.
    </div>

    <div class="mt-2 text-xs text-white/50">
      Powered by <a href="https://hyppohq.ai" target="_blank" rel="noopener noreferrer" class="underline hover:text-brand-red transition-colors">HyppoAI</a>
    </div>
  </div>
</footer>
